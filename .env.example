# Claude Terminal — Configuration
# Run `node setup.js` to generate this file automatically.

# JWT secret (generated by setup.js)
# To generate manually: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_byte_hex_secret_here

# Session timeout in hours
SESSION_TIMEOUT_HOURS=24

# Server bind address
# 127.0.0.1 = local only (default, behind reverse proxy)
# 0.0.0.0 = all interfaces (Docker, direct access)
HOST=127.0.0.1

# Public URL (for email links)
APP_URL=https://your-domain.com

# Guest access code (optional — any string)
#GUEST_ACCESS_CODE=your_guest_code_here

# Admin email for registration approval notifications (optional)
#ADMIN_EMAIL=admin@example.com

# SMTP settings (optional — without SMTP, approve users via admin panel or CLI)
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USER=your_email@gmail.com
#SMTP_PASS=your_app_password
